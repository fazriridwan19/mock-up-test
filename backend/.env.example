# Application
APP_PORT=3000
APP_ENV=development

# JWT — Access Token (short-lived, stored in httpOnly cookie)
JWT_ACCESS_SECRET=change_this_access_secret_in_production
JWT_ACCESS_EXPIRES_IN=15m

# JWT — Refresh Token (long-lived, stored in httpOnly cookie, hashed in DB)
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production_use_different_value
JWT_REFRESH_EXPIRES_IN=7d

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=password
DB_DATABASE=edi_biodata

# Redis (for BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
