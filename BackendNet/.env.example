# Override appsettings.json values via environment variables.
# ASP.NET Core maps "Section__Key" env vars to "Section:Key" config keys.

# JWT
Jwt__AccessSecret=change_this_access_secret_in_production
Jwt__RefreshSecret=change_this_refresh_secret_in_production_use_different_value
Jwt__AccessExpiresIn=15m
Jwt__RefreshExpiresIn=7d

# Database (MySQL)
ConnectionStrings__Default=Server=localhost;Port=3306;Database=edi_biodata;User=root;Password=password;

# Redis
Redis__Connection=localhost:6379

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000
